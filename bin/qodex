#!/usr/bin/env zsh

set -euo pipefail

readonly HEALTHCHECK_FLAG="--healthcheck"
readonly DEFAULT_CODEX_HOME="$HOME/.codex-min"
readonly DEFAULT_WORKDIR="/tmp"
readonly SCRIPT_DIR="${0:A:h}"

source "$SCRIPT_DIR/lib/bootstrap-fast-cli-env.zsh"

ensure_codex_min_home || exit 1

if [[ "${1:-}" == "$HEALTHCHECK_FLAG" ]]; then
  exit 0
fi

export CODEX_HOME="${CODEX_MIN_HOME:-$DEFAULT_CODEX_HOME}"
exec codex exec --skip-git-repo-check -C "${QODEX_WORKDIR:-$DEFAULT_WORKDIR}" "$@"
